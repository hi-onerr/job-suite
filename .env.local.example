# ── Database (Neon Postgres or any Postgres) ─────────────────────────────────
# Neon: create a project at https://neon.tech and copy the connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Auth.js (NextAuth) ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=generate_a_random_32_byte_base64_string

# Google OAuth credentials — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# ── API key encryption (AES-256-GCM) ─────────────────────────────────────────
# Must decode to exactly 32 bytes. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=generate_a_random_32_byte_base64_string

# ── AI (optional fallback) ────────────────────────────────────────────────────
# Per-user keys are stored in the DB via Settings. This env var is only a
# fallback default if a user has not set their own Gemini key.
# GEMINI_API_KEY=your_gemini_api_key_here
